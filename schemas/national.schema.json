{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "National Ecosystem Data",
  "type": "object",
  "required": ["countryName", "countryCode", "lastUpdated", "ecosystems", "metadata"],
  "properties": {
    "countryName": { "type": "string", "minLength": 1 },
    "countryCode": { "type": "string", "minLength": 2 },
    "lastUpdated": { "type": "string", "format": "date" },
    "ecosystems": {
      "type": "object",
      "required": ["coralReef", "reefFlats", "seagrass", "mangroves"],
      "properties": {
        "coralReef": { "type": "number", "minimum": 0 },
        "reefFlats": { "type": "number", "minimum": 0 },
        "seagrass": { "type": "number", "minimum": 0 },
        "mangroves": { "type": "number", "minimum": 0 },
        "algae": { "type": ["number", "null"], "minimum": 0 },
        "tidalWetlands": { "type": ["number", "null"], "minimum": 0 },
        "other": { "type": ["number", "null"], "minimum": 0 },
        "rubbleBrokenCoral": { "type": ["number", "null"], "minimum": 0 },
        "sand": { "type": ["number", "null"], "minimum": 0 },
        "pavement": { "type": ["number", "null"], "minimum": 0 },
        "rubble": { "type": ["number", "null"], "minimum": 0 },
        "denseSeagrass": { "type": ["number", "null"], "minimum": 0 },
        "lightSeagrass": { "type": ["number", "null"], "minimum": 0 }
      },
      "additionalProperties": false
    },
    "areaUnit": { "type": "string", "enum": ["ha", "m2"] },
    "featuredEcosystems": {
      "type": "array",
      "items": { "$ref": "#/$defs/ecosystemKey" }
    },
    "ecosystemConditionLabels": {
      "type": "object",
      "properties": {
        "coralReef": { "type": ["string", "null"] },
        "reefFlats": { "type": ["string", "null"] },
        "seagrass": { "type": ["string", "null"] },
        "mangroves": { "type": ["string", "null"] },
        "algae": { "type": ["string", "null"] },
        "tidalWetlands": { "type": ["string", "null"] },
        "other": { "type": ["string", "null"] },
        "rubbleBrokenCoral": { "type": ["string", "null"] },
        "sand": { "type": ["string", "null"] },
        "pavement": { "type": ["string", "null"] },
        "rubble": { "type": ["string", "null"] },
        "denseSeagrass": { "type": ["string", "null"] },
        "lightSeagrass": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "metadata": {
      "type": "object",
      "required": ["dataSource", "methodology", "referenceYear"],
      "properties": {
        "dataSource": { "type": "string", "minLength": 1 },
        "methodology": { "type": "string", "minLength": 1 },
        "referenceYear": { "type": "integer" },
        "spatialResolution": { "type": ["string", "null"] },
        "uncertaintyRange": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "ecosystemServices": {
      "type": "object",
      "properties": {
        "ecosystems": {
          "type": "array",
          "items": { "$ref": "#/$defs/ecosystemServiceGroup" }
        },
        "metadata": {
          "type": "object",
          "properties": {
            "dataSource": { "type": "string" },
            "methodology": { "type": "string" },
            "notes": { "type": ["string", "null"] }
          }
        }
      }
    },
    "naturalCapital": {
      "type": "object",
      "properties": {
        "year": { "type": "integer" },
        "title": { "type": "string" },
        "categories": {
          "type": "array",
          "items": { "$ref": "#/$defs/naturalCapitalCategory" }
        },
        "clusters": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "metadata": {
          "type": "object",
          "properties": {
            "dataSource": { "type": "string" },
            "notes": { "type": ["string", "null"] }
          }
        }
      }
    },
    "social": {
      "type": "object",
      "required": ["lastUpdated", "spotlightAtollId", "indicators", "atolls"],
      "properties": {
        "lastUpdated": { "type": "string", "format": "date" },
        "spotlightAtollId": { "type": "string", "minLength": 1 },
        "indicators": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/nationalSocialIndicatorDefinition" }
        },
        "atolls": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/nationalSocialAtoll" }
        },
        "notes": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "ecosystemServiceValue": {
      "type": "object",
      "required": ["year", "value"],
      "properties": {
        "year": { "type": "integer" },
        "value": { "type": "number", "minimum": 0 }
      }
    },
    "ecosystemServiceMetric": {
      "type": "object",
      "required": ["id", "label", "unit", "values"],
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "unit": { "type": "string" },
        "values": {
          "type": "array",
          "items": { "$ref": "#/$defs/ecosystemServiceValue" }
        },
        "breakdown": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["label", "value"],
            "properties": {
              "label": { "type": "string" },
              "value": { "type": "number", "minimum": 0 },
              "unit": { "type": ["string", "null"] }
            },
            "additionalProperties": false
          }
        }
      }
    },
    "ecosystemKey": {
      "type": "string",
      "enum": [
        "coralReef",
        "reefFlats",
        "seagrass",
        "mangroves",
        "algae",
        "tidalWetlands",
        "other",
        "rubbleBrokenCoral",
        "sand",
        "pavement",
        "rubble",
        "denseSeagrass",
        "lightSeagrass"
      ]
    },
    "ecosystemServiceGroup": {
      "type": "object",
      "required": ["ecosystem", "ecosystemLabel", "metrics"],
      "properties": {
        "ecosystem": { "type": "string" },
        "ecosystemLabel": { "type": "string" },
        "metrics": {
          "type": "array",
          "items": { "$ref": "#/$defs/ecosystemServiceMetric" }
        }
      }
    },
    "naturalCapitalCategory": {
      "type": "object",
      "required": ["id", "label", "unit", "provision", "usage"],
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "unit": { "type": "string" },
        "provision": { "type": "number", "minimum": 0 },
        "usage": {
          "type": "object",
          "additionalProperties": { "type": "number", "minimum": 0 }
        }
      }
    },
    "socialTierLabels": {
      "type": "object",
      "required": ["low", "moderate", "high"],
      "properties": {
        "low": { "type": "string" },
        "moderate": { "type": "string" },
        "high": { "type": "string" }
      },
      "additionalProperties": false
    },
    "nationalSocialIndicatorDefinition": {
      "type": "object",
      "required": ["id", "label", "description", "icon", "unit"],
      "properties": {
        "id": {
          "type": "string",
          "enum": [
            "fishingIncomeDependency",
            "foodSecurityDependence",
            "stormSurgeExposure",
            "tourismEmploymentShare",
            "youthPopulationShare",
            "populationSize",
            "weeklyFishSeafoodSpend",
            "coastalDamageExposure"
          ]
        },
        "label": { "type": "string" },
        "shortLabel": { "type": ["string", "null"] },
        "description": { "type": "string" },
        "icon": {
          "type": "string",
          "enum": [
            "boat",
            "meal",
            "wave",
            "tourism",
            "youth",
            "population",
            "currency",
            "damage"
          ]
        },
        "unit": {
          "type": "string",
          "enum": ["percentage", "number", "currency"]
        },
        "tierLabels": { "$ref": "#/$defs/socialTierLabels" }
      },
      "additionalProperties": false
    },
    "socialMetric": {
      "type": "object",
      "required": ["value", "tier"],
      "properties": {
        "value": { "type": ["number", "null"] },
        "tier": {
          "type": ["string", "null"],
          "enum": ["low", "moderate", "high", null]
        },
        "iconCount": { "type": ["integer", "null"], "minimum": 1, "maximum": 3 },
        "percentile": { "type": ["number", "null"], "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "socialMetricsMap": {
      "type": "object",
      "required": [
        "fishingIncomeDependency",
        "foodSecurityDependence",
        "stormSurgeExposure",
        "tourismEmploymentShare",
        "youthPopulationShare",
        "populationSize",
        "weeklyFishSeafoodSpend",
        "coastalDamageExposure"
      ],
      "properties": {
        "fishingIncomeDependency": { "$ref": "#/$defs/socialMetric" },
        "foodSecurityDependence": { "$ref": "#/$defs/socialMetric" },
        "stormSurgeExposure": { "$ref": "#/$defs/socialMetric" },
        "tourismEmploymentShare": { "$ref": "#/$defs/socialMetric" },
        "youthPopulationShare": { "$ref": "#/$defs/socialMetric" },
        "populationSize": { "$ref": "#/$defs/socialMetric" },
        "weeklyFishSeafoodSpend": { "$ref": "#/$defs/socialMetric" },
        "coastalDamageExposure": { "$ref": "#/$defs/socialMetric" }
      },
      "additionalProperties": false
    },
    "nationalSocialAtoll": {
      "type": "object",
      "required": ["id", "name", "metrics"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "metrics": { "$ref": "#/$defs/socialMetricsMap" },
        "isSpotlight": { "type": "boolean" },
        "population": { "type": ["number", "null"], "minimum": 0 }
      },
      "additionalProperties": false
    }
  }
}
