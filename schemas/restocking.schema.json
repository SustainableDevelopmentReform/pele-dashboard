{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Restocking Area Data",
  "type": "object",
  "required": ["species"],
  "properties": {
    "species": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "label", "displayName", "sites"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "displayName": { "type": "string", "minLength": 1 },
          "mapImage": { "type": ["string", "null"] },
          "mapLink": {
            "anyOf": [{ "$ref": "#/$defs/externalLink" }, { "type": "null" }]
          },
          "sites": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/$defs/site" }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "externalLink": {
      "type": "object",
      "required": ["label", "url"],
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "format": "uri-reference" }
      },
      "additionalProperties": false
    },
    "coordinates": {
      "type": "object",
      "required": ["latitude", "longitude"],
      "properties": {
        "latitude": { "type": "number", "minimum": -90, "maximum": 90 },
        "longitude": { "type": "number", "minimum": -180, "maximum": 180 }
      },
      "additionalProperties": false
    },
    "survey": {
      "type": "object",
      "required": ["year", "speciesAndSize", "restockingDate"],
      "properties": {
        "year": { "type": "integer" },
        "clamsPlaced": { "type": ["number", "null"], "minimum": 0 },
        "individualsPlaced": { "type": ["number", "null"], "minimum": 0 },
        "speciesAndSize": { "type": "string", "minLength": 1 },
        "restockingDate": { "type": "string", "format": "date" },
        "survivalRate6mo": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "notes": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "site": {
      "type": "object",
      "required": ["id", "village", "surveys"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "village": { "type": "string", "minLength": 1 },
        "description": { "type": ["string", "null"] },
        "coordinates": {
          "anyOf": [{ "$ref": "#/$defs/coordinates" }, { "type": "null" }]
        },
        "surveys": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/survey" }
        }
      },
      "additionalProperties": false
    }
  }
}
