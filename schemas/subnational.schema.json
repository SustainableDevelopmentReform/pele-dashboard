{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Subnational Ecosystem Data",
  "type": "object",
  "$defs": {
    "socialIndicatorId": {
      "enum": [
        "fishingIncomeDependency",
        "foodSecurityDependence",
        "stormSurgeExposure",
        "tourismEmploymentShare",
        "youthPopulationShare",
        "populationSize",
        "weeklyFishSeafoodSpend",
        "coastalDamageExposure"
      ]
    },
    "socialTier": {
      "enum": ["low", "moderate", "high", null]
    },
    "socialIcon": {
      "enum": [
        "boat",
        "meal",
        "wave",
        "tourism",
        "youth",
        "population",
        "currency",
        "damage"
      ]
    },
    "socialUnit": {
      "enum": ["percentage", "number", "currency"]
    },
    "ecosystemKey": {
      "type": "string",
      "enum": [
        "coralReef",
        "reefFlats",
        "seagrass",
        "mangroves",
        "algae",
        "tidalWetlands",
        "other",
        "rubbleBrokenCoral",
        "sand",
        "pavement",
        "rubble",
        "denseSeagrass",
        "lightSeagrass"
      ]
    },
    "externalLink": {
      "type": "object",
      "required": ["label", "url"],
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "format": "uri" }
      },
      "additionalProperties": false
    },
    "ecosystemConditionLabels": {
      "type": "object",
      "properties": {
        "coralReef": { "type": ["string", "null"] },
        "reefFlats": { "type": ["string", "null"] },
        "seagrass": { "type": ["string", "null"] },
        "mangroves": { "type": ["string", "null"] },
        "algae": { "type": ["string", "null"] },
        "tidalWetlands": { "type": ["string", "null"] },
        "other": { "type": ["string", "null"] },
        "rubbleBrokenCoral": { "type": ["string", "null"] },
        "sand": { "type": ["string", "null"] },
        "pavement": { "type": ["string", "null"] },
        "rubble": { "type": ["string", "null"] },
        "denseSeagrass": { "type": ["string", "null"] },
        "lightSeagrass": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "socialTierLabels": {
      "type": "object",
      "required": ["low", "moderate", "high"],
      "properties": {
        "low": { "type": "string" },
        "moderate": { "type": "string" },
        "high": { "type": "string" }
      },
      "additionalProperties": false
    },
    "socialIndicatorDefinition": {
      "type": "object",
      "required": ["id", "label", "description", "icon", "unit"],
      "properties": {
        "id": {
          "type": "string",
          "enum": [
            "fishingIncomeDependency",
            "foodSecurityDependence",
            "stormSurgeExposure",
            "tourismEmploymentShare",
            "youthPopulationShare",
            "populationSize",
            "weeklyFishSeafoodSpend",
            "coastalDamageExposure"
          ]
        },
        "label": { "type": "string" },
        "shortLabel": { "type": ["string", "null"] },
        "description": { "type": "string" },
        "icon": {
          "type": "string",
          "enum": [
            "boat",
            "meal",
            "wave",
            "tourism",
            "youth",
            "population",
            "currency",
            "damage"
          ]
        },
        "unit": {
          "type": "string",
          "enum": ["percentage", "number", "currency"]
        },
        "tierLabels": { "$ref": "#/$defs/socialTierLabels" }
      },
      "additionalProperties": false
    },
    "socialMetric": {
      "type": "object",
      "required": ["value", "tier"],
      "properties": {
        "value": { "type": ["number", "null"] },
        "tier": {
          "type": ["string", "null"],
          "enum": ["low", "moderate", "high", null]
        },
        "iconCount": { "type": ["integer", "null"], "minimum": 1, "maximum": 3 },
        "percentile": { "type": ["number", "null"], "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "socialMetricsMap": {
      "type": "object",
      "required": [
        "fishingIncomeDependency",
        "foodSecurityDependence",
        "stormSurgeExposure",
        "tourismEmploymentShare",
        "youthPopulationShare",
        "populationSize",
        "weeklyFishSeafoodSpend",
        "coastalDamageExposure"
      ],
      "properties": {
        "fishingIncomeDependency": { "$ref": "#/$defs/socialMetric" },
        "foodSecurityDependence": { "$ref": "#/$defs/socialMetric" },
        "stormSurgeExposure": { "$ref": "#/$defs/socialMetric" },
        "tourismEmploymentShare": { "$ref": "#/$defs/socialMetric" },
        "youthPopulationShare": { "$ref": "#/$defs/socialMetric" },
        "populationSize": { "$ref": "#/$defs/socialMetric" },
        "weeklyFishSeafoodSpend": { "$ref": "#/$defs/socialMetric" },
        "coastalDamageExposure": { "$ref": "#/$defs/socialMetric" }
      },
      "additionalProperties": false
    },
    "populationDistribution": {
      "type": "object",
      "required": ["total", "males", "females", "ageDistribution"],
      "properties": {
        "total": { "type": "number", "minimum": 0 },
        "males": { "type": ["number", "null"], "minimum": 0 },
        "females": { "type": ["number", "null"], "minimum": 0 },
        "ageDistribution": {
          "type": "object",
          "required": ["age0to14", "age15to64", "age65plus"],
          "properties": {
            "age0to14": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
            "age15to64": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
            "age65plus": { "type": ["number", "null"], "minimum": 0, "maximum": 100 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "socioeconomicProfile": {
      "type": "object",
      "required": [
        "totalPopulation",
        "households",
        "femaleShare",
        "dependencyRatio",
        "disabilityShare",
        "unemploymentShare",
        "tourismWorkers",
        "tourismShare",
        "fishingHouseholds",
        "oceanResourcesShare"
      ],
      "properties": {
        "totalPopulation": { "type": ["number", "null"], "minimum": 0 },
        "households": { "type": ["number", "null"], "minimum": 0 },
        "femaleShare": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
        "dependencyRatio": { "type": ["number", "null"], "minimum": 0 },
        "disabilityShare": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
        "unemploymentShare": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
        "tourismWorkers": { "type": ["number", "null"], "minimum": 0 },
        "tourismShare": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
        "fishingHouseholds": { "type": ["number", "null"], "minimum": 0 },
        "oceanResourcesShare": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 100
        }
      },
      "additionalProperties": false
    }
  },
  "required": ["areas"],
  "properties": {
    "areas": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "type", "ecosystems"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "minLength": 1 },
          "description": { "type": ["string", "null"] },
          "spatialLink": {
            "anyOf": [{ "$ref": "#/$defs/externalLink" }, { "type": "null" }]
          },
          "featuredEcosystems": {
            "type": "array",
            "items": { "$ref": "#/$defs/ecosystemKey" }
          },
          "ecosystemConditionLabels": { "$ref": "#/$defs/ecosystemConditionLabels" },
          "coordinates": {
            "type": "object",
            "required": ["latitude", "longitude"],
            "properties": {
              "latitude": { "type": "number", "minimum": -90, "maximum": 90 },
              "longitude": { "type": "number", "minimum": -180, "maximum": 360 }
            },
            "additionalProperties": false
          },
          "ecosystems": {
            "type": "object",
            "required": ["coralReef", "reefFlats", "seagrass", "mangroves"],
            "properties": {
              "coralReef": { "type": "number", "minimum": 0 },
              "reefFlats": { "type": "number", "minimum": 0 },
              "seagrass": { "type": "number", "minimum": 0 },
              "mangroves": { "type": "number", "minimum": 0 },
              "algae": { "type": ["number", "null"], "minimum": 0 },
              "tidalWetlands": { "type": ["number", "null"], "minimum": 0 },
              "other": { "type": ["number", "null"], "minimum": 0 },
              "rubbleBrokenCoral": { "type": ["number", "null"], "minimum": 0 },
              "sand": { "type": ["number", "null"], "minimum": 0 },
              "pavement": { "type": ["number", "null"], "minimum": 0 },
              "rubble": { "type": ["number", "null"], "minimum": 0 },
              "denseSeagrass": { "type": ["number", "null"], "minimum": 0 },
              "lightSeagrass": { "type": ["number", "null"], "minimum": 0 }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "spatialLink": {
      "anyOf": [{ "$ref": "#/$defs/externalLink" }, { "type": "null" }]
    },
    "social": {
      "type": "object",
      "required": [
        "lastUpdated",
        "atollId",
        "atollName",
        "indicators",
        "atollAverages",
        "islands"
      ],
      "properties": {
        "lastUpdated": { "type": "string", "format": "date" },
        "atollId": { "type": "string", "minLength": 1 },
        "atollName": { "type": "string", "minLength": 1 },
        "indicators": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/socialIndicatorDefinition" }
        },
        "atollAverages": { "$ref": "#/$defs/socialMetricsMap" },
        "islands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "name", "atollId", "metrics"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "name": { "type": "string", "minLength": 1 },
              "atollId": { "type": "string", "minLength": 1 },
              "metrics": { "$ref": "#/$defs/socialMetricsMap" },
              "population": { "type": ["number", "null"], "minimum": 0 },
              "populationDistribution": {
                "anyOf": [
                  { "$ref": "#/$defs/populationDistribution" },
                  { "type": "null" }
                ]
              },
              "socioeconomic": {
                "anyOf": [{ "$ref": "#/$defs/socioeconomicProfile" }, { "type": "null" }]
              }
            },
            "additionalProperties": false
          }
        },
        "notes": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
